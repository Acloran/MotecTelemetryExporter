# Copy to .env when credentials are available. Keep .env out of git.
ORION_DB_HOST=192.168.1.109
ORION_DB_PORT=5432
ORION_DB_NAME=orion
ORION_DB_USER=analysis
ORION_DB_PASSWORD=
ORION_DB_SSLMODE=disable
ORION_DB_CONNECT_TIMEOUT=5

# Use "sample" until DB credentials exist. Use "postgres" when ready.
TELEMETRY_SOURCE=sample

# Local paths only. These are gitignored by default.
EXPORT_DIR=exports
TRACK_DIR=tracks
CHANNEL_CHART_DIR=channel_charts
CACHE_DIR=.cache
DISPLAY_TIMEZONE=America/Chicago

# Live viewer. lhre-2026 publishes JSON to grafana_data_<car> topics.
# Use local for replay simulator -> live viewer on this computer. Use kafka for a real broker.
KAFKA_MODE=local
KAFKA_BOOTSTRAP_SERVERS=192.168.1.109:29092
KAFKA_TOPIC_PREFIX=grafana_data
KAFKA_CONSUMER_TIMEOUT_MS=1000
LIVE_MQTT_HOST=18.191.225.118
LIVE_MQTT_PORT=1883
LIVE_MQTT_TOPIC=orion

# Conservative defaults protect the remote server during preview/export work.
MAX_PREVIEW_POINTS=5000
MAX_PREVIEW_SECONDS=7200
MAX_AUTO_SPLIT_SECONDS=1800
MAX_EXPORT_SECONDS=1800
